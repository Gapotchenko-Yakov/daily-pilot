// prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  tasks     Task[]
  finances  Finance[]
  createdAt DateTime  @default(now())
}

model Task {
  id          Int        @id @default(autoincrement())
  title       String
  description String?
  dueDate     DateTime?
  status      TaskStatus @default(PENDING)
  user        User       @relation(fields: [userId], references: [id])
  userId      Int
  createdAt   DateTime   @default(now())
}

model Finance {
  id          Int         @id @default(autoincrement())
  description String
  amount      Float
  type        FinanceType
  date        DateTime    @default(now())
  user        User        @relation(fields: [userId], references: [id])
  userId      Int
  createdAt   DateTime    @default(now())
}

enum TaskStatus {
  PENDING
  COMPLETED
  IN_PROGRESS
}

enum FinanceType {
  INCOME
  EXPENSE
}
